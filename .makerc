MAKEVAR_ROOT_DIR :=$(shell dirname $(realpath $(lastword $(MAKEFILE_LIST))))

# Project MAKEVAR_LOGO in ASCII
MAKEVAR_LOGO :

ifeq (${MAKEVAR_CATAPULT_VERSION}, staging)
    MAKEVAR_IMAGE_TAG :=staging
else
    MAKEVAR_IMAGE_TAG :=$(shell cat version.yml | cut -d ' ' -f 2)
endif

MAKEVAR_HOST_OS :=$(shell uname)
MAKEVAR_HOST_USER_HOME :=$(shell echo ~)
MAKEVAR_HOST_USERNAME :=${USER}
MAKEVAR_HOST_USER_ID :=$(shell id -u)

# Because default MacOS user group ID already exists in container
ifeq (${MAKEVAR_HOST_OS}, Darwin)
    MAKEVAR_CONTAINER_GROUP_ID :=$(or ${MAKEVAR_CONTAINER_GROUP_ID},$(shell id -u) )
else
    MAKEVAR_CONTAINER_GROUP_ID :=$(or ${MAKEVAR_CONTAINER_GROUP_ID},$(shell id -g) )
endif

ifeq (${MAKEVAR_HOST_USER_ID}, 1000)
    MAKEVAR_IMAGE_FULL :=${MAKEVAR_CONTAINER_REGISTRY}/${MAKEVAR_IMAGE_NAME}:${MAKEVAR_IMAGE_TAG}
else ifeq (${MAKEVAR_HOST_OS}, Darwin)
    MAKEVAR_IMAGE_FULL :=${MAKEVAR_CONTAINER_REGISTRY}/${MAKEVAR_IMAGE_NAME}:${MAKEVAR_IMAGE_TAG}
else
    MAKEVAR_IMAGE_FULL :=locally-built-catapult:${MAKEVAR_IMAGE_TAG}
endif

MAKEVAR_CONTAINER_ENTRYPOINT :=zsh
MAKEVAR_CONTAINER_PROJECT_NAME :=$(shell echo $(MAKEVAR_COMPOSE_PROJECT_NAME) | tr '[:upper:]' '[:lower:]')
MAKEVAR_CONTAINER_NAME :=${MAKEVAR_CONTAINER_PROJECT_NAME}-${MAKEVAR_HOST_USERNAME}
MAKEVAR_BUILD_ARGS := --build-arg MAKEVAR_CONTAINER_USER_ID=${MAKEVAR_HOST_USER_ID} --build-arg MAKEVAR_CONTAINER_GROUP_ID=${MAKEVAR_CONTAINER_GROUP_ID} --build-arg TZ=${MAKEVAR_TZ}

# Random generated secret key for ARA
# It will be used as username and password for database connection
MAKEVAR_ARA_SECRET_KEY :=$(shell openssl rand -hex 12)
MAKEVAR_ARA_DATABASE_PASSWORD :=${MAKEVAR_ARA_SECRET_KEY}
MAKEVAR_ARA_DATABASE_USERNAME :=${MAKEVAR_ARA_SECRET_KEY}
MAKEVAR_ARA_RECORD_CONTROLLER_NAME :=${MAKEVAR_CONTAINER_NAME}
MAKEVAR_ARA_RECORD_USERNAME :=${MAKEVAR_HOST_USERNAME}

# Setting the bind addresses based on whether to listen on localhost only or all interfaces
ifeq (${MAKEVAR_ARA_LOCALHOST_ONLY}, 1)
    MAKEVAR_ARA_BIND_COMMAND =--bind [127.0.0.1]:8000 --bind [::1]:8000
else
    MAKEVAR_ARA_BIND_COMMAND =--bind [::]:8000
endif
